PORT=3001

# JWT secret - change this to a long random string in production
JWT_SECRET=change_me_to_a_long_random_secret_string

# Optional: GitHub personal access token for higher API rate limits
GITHUB_TOKEN=

# Optional: OpenAI API key for the AI chatbot
OPENAI_API_KEY=

# Frontend origin for CORS (comma-separated for multiple)
CLIENT_ORIGIN=http://localhost:5173
